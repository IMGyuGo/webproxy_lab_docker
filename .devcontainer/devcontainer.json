{
    "name": "Proxylab Development Container",
    "dockerFile": "Dockerfile",
    "remoteUser": "jungle",
    "forwardPorts": [
        12345
    ],
    "portsAttributes": {
        "3000": {
            "label": "Application",
            "onAutoForward": "notify"
        },
        "12345": {
            "label": "echoserver"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools-extension-pack",
                "ms-vscode.cpptools"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash",
                "C_Cpp.default.includePath": [
                    "/usr/include",
                    "/usr/local/include"
                ],
                "C_Cpp.default.compilerPath": "/usr/bin/gcc"
            }
        }
    }
}